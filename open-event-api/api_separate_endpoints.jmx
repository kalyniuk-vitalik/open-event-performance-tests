      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Endpoint Labeler" enabled="true">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">import org.apache.jmeter.protocol.http.sampler.HTTPSamplerBase

// Get current sampler and ensure it&apos;s an HTTP sampler
def s = sampler
if (!(s instanceof HTTPSamplerBase)) return

def http = (HTTPSamplerBase) s

// Read HTTP method
def method = http.getMethod()
if (!method) return

// Read request path (may include query string)
def path = http.getPath()
if (!path) return

// Strip query string to avoid too many unique labels
int q = path.indexOf(&apos;?&apos;)
if (q &gt;= 0) path = path.substring(0, q)

// Ensure path starts with &apos;/&apos;
if (path.charAt(0) != &apos;/&apos;) path = &apos;/&apos; + path

// Build label like: &quot;GET /api/v1/users&quot;
def newLabel = method + &apos; &apos; + path

// Update Sample Label shown in listeners/reports
prev.setSampleLabel(newLabel)

// Ignore &quot;setup auth&quot; samplers so they don&apos;t go to JTL/HTML/Grafana
def name = sampler?.getName()
if (name != null &amp;&amp; name.startsWith(&apos;setup auth |&apos;)) {
    prev.setIgnore()
}
</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </JSR223PostProcessor>
