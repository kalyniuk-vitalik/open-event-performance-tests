        <stringProp name="connectionAge">5000</stringProp>
        <stringProp name="connectionProperties"></stringProp>
        <stringProp name="dataSource">events_api</stringProp>
        <stringProp name="dbUrl">jdbc:postgresql://${DATABASE_URL}:5432/oevent</stringProp>
