          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Append SESSION_ID" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">//def id = vars.get(&apos;SESSION_ID&apos;)
//def cur = vars.get(&apos;SESSIONS_DATA&apos;)
//
//def item = &quot;&quot;&quot;{&quot;type&quot;:&quot;session&quot;,&quot;id&quot;:&quot;${id}&quot;}&quot;&quot;&quot;
//if (cur == null || cur.isEmpty()) {
//  vars.put(&apos;SESSIONS_DATA&apos;, item)
//} else {
//  vars.put(&apos;SESSIONS_DATA&apos;, cur + &quot;,&quot; + item)
//}

def id = vars.get(&apos;SESSION_ID&apos;)
def cur = vars.get(&apos;sessionsData&apos;)

// перший елемент без коми, наступні — з комою
def item = &quot;&quot;&quot;{&quot;type&quot;:&quot;session&quot;,&quot;id&quot;:&quot;${id}&quot;}&quot;&quot;&quot;
if (cur == null || cur.isEmpty()) {
  vars.put(&apos;sessionsData&apos;, item)
} else {
  vars.put(&apos;sessionsData&apos;, cur + &quot;,&quot; + item)
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /v1/speakers" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
  &quot;data&quot;: {&#xd;
    &quot;type&quot;: &quot;speaker&quot;,&#xd;
    &quot;relationships&quot;: {&#xd;
      &quot;event&quot;: {&#xd;
        &quot;data&quot;: {&#xd;
          &quot;type&quot;: &quot;event&quot;,&#xd;
          &quot;id&quot;: &quot;${EVENT_ID}&quot;&#xd;
        }&#xd;
      },&#xd;
      &quot;user&quot;: {&#xd;
        &quot;data&quot;: {&#xd;
          &quot;type&quot;: &quot;user&quot;,&#xd;
          &quot;id&quot;: &quot;1&quot;&#xd;
        }&#xd;
      },&#xd;
      &quot;sessions&quot;: {&#xd;
        &quot;data&quot;: [&#xd;
        	${sessionsData}&#xd;
        ]&#xd;
      }&#xd;
    },&#xd;
    &quot;attributes&quot;: {&#xd;
      &quot;name&quot;: &quot;${__RandomString(8,asdfghjuikmnbvcxzwe,TICKET-NAME)}&quot;,&#xd;
      &quot;email&quot;: &quot;${__RandomString(8,asdfghjuikmnbvcxzwe,TICKET-NAME)}@example.com&quot;,&#xd;
      &quot;website&quot;: &quot;https://${__RandomString(8,asdfghjuikmnbvcxzwe)}.com&quot;,&#xd;
      &quot;city&quot;: &quot;${__chooseRandom(Kyiv,Warsaw,Berlin,Prague,Vienna,Budapest,Rome,Paris,Madrid,Lisbon,0)}&quot;,&#xd;
      &quot;gender&quot;: &quot;${__chooseRandom(Man,Woman,0)}&quot;,&#xd;
      &quot;country&quot;: &quot;${__chooseRandom(,Ukraine,Poland,Germany,Czechia,Austria,Hungary,Italy,France,Spain,Portugal,0)}&quot;&#xd;
    }&#xd;
  }&#xd;
}&#xd;
&#xd;
</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${DOMAIN}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">${PROTOCOL}</stringProp>
          <stringProp name="HTTPSampler.contentEncoding"></stringProp>
          <stringProp name="HTTPSampler.path">/v1/speakers</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
          <stringProp name="HTTPSampler.connect_timeout"></stringProp>
          <stringProp name="HTTPSampler.response_timeout"></stringProp>
        </HTTPSamplerProxy>
